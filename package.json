{
  "name": "n8n-nodes-maxio",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Maxio (Chargify) B2B subscription billing platform providing 12 resources and 80+ operations for subscription management, invoicing, customer accounts, and payment processing.",
  "license": "SEE LICENSE IN LICENSE.md",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-maxio.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-maxio",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-maxio/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "maxio",
    "chargify",
    "subscription",
    "billing",
    "invoicing",
    "payment",
    "saas",
    "b2b",
    "revenue",
    "automation"
  ],
  "main": "dist/nodes/Maxio/Maxio.node.js",
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/MaxioApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Maxio/Maxio.node.js",
      "dist/nodes/Maxio/MaxioTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rm -rf dist/"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "1.57.0",
    "prettier": "^3.2.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}